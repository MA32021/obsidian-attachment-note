  "description": "Create markdown notes for binary files with MD5 hash tracking",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.28.0",
